@echo off
chcp 65001 >nul
echo ================================================================================
echo 🔍 포트 사용 상태 확인
echo ================================================================================
echo.

echo 📍 포트 32577 (백엔드) 확인 중...
netstat -ano | findstr :32577
if %errorlevel% equ 0 (
    echo    ⚠️  포트 32577이 사용 중입니다
) else (
    echo    ✅ 포트 32577 사용 가능
)

echo.
echo 📍 포트 3000 (프론트엔드) 확인 중...
netstat -ano | findstr :3000
if %errorlevel% equ 0 (
    echo    ⚠️  포트 3000이 사용 중입니다
) else (
    echo    ✅ 포트 3000 사용 가능
)

echo.
echo ================================================================================
echo 💡 포트가 사용 중이면 stop.bat을 실행하여 서버를 종료하세요
echo ================================================================================
echo.
pause

